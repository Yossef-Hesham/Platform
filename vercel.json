{

    
    "builds": [
        { 
            "src": "Platform/Wsgi.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "15mb",
                "runtime": "python3.12",
                "buildCommand":"bash setup.sh"
            }
        }
    ],
    "routes": [
        { 
            "src": "/(.*)",
            "dest": "Platform/Wsgi.py" 
        }, 
        {
            "src": "/static/(.*)", 
            "dest": "/static/$1"
        }
    ]

}